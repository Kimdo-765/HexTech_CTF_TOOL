# Anthropic API key. Leave empty to use Claude Code OAuth instead — run
# `claude login` on the host once and the worker mounts ~/.claude so the
# bundled `claude` CLI uses your claude.ai subscription token.
ANTHROPIC_API_KEY=

# Override if your host's Claude config is not at ~/.claude
# HOST_CLAUDE_HOME=/home/youruser/.claude

# Claude model to use (default: claude-opus-4-7 with 1M context)
CLAUDE_MODEL=claude-opus-4-7

# Per-turn max output tokens passed to the SDK. We default to a very
# large number so the model's own ceiling (Sonnet/Opus ~64k) becomes
# the effective limit and the agent never gets truncated mid-thought.
# Lower this if you want to cap spend / response length.
CLAUDE_CODE_MAX_OUTPUT_TOKENS=999999

# Trip-wire: stop a web/pwn/crypto/rev job after this many tool calls
# if the agent still hasn't written exploit.py / solver.py. Catches
# investigation-loop runaway before the SDK exhausts the conversation
# context. 0 disables the trip-wire.
INVESTIGATION_BUDGET=0

# Redis (default points to docker-compose service)
REDIS_URL=redis://redis:6379/0

# Web UI port
WEB_PORT=8000

# Auto-start the cloudflared OOB tunnel on bring-up. When 1 (default),
# ./start.sh and ./restart.sh launch tunnel.sh in the background, which runs a
# cloudflared quick-tunnel and auto-sets the Callback URL in /data/settings.json
# (no ngrok interstitial, no manual copy). Set 0 to skip (e.g. you run your own
# tunnel). No-ops cleanly if cloudflared isn't installed. Stop a running tunnel
# with `./tunnel.sh stop`.
AUTO_TUNNEL=1

# Soft job execution timeout (seconds). When this elapses while the agent is
# still running, the UI prompts you to continue or kill the job. RQ's hard
# kill ceiling is set automatically to a much larger value (4× soft, min 24h)
# so the in-worker watchdog has time to fire.
JOB_TIMEOUT=6000

# Absolute host path of ./data — required by Pwn/Forensic/Misc modules so
# the worker can bind-mount the job directory into sibling containers
# spawned via docker.sock. Set this to the absolute path of <repo>/data.
HOST_DATA_DIR=/home/youruser/HexTech_CTF_TOOL/data

# Number of parallel worker processes (concurrent jobs). Each pulls
# independently from the same Redis queue. Restart the worker container
# (`docker compose restart worker`) for changes to take effect.
WORKER_CONCURRENCY=3

# Job retention. Jobs older than this many days are auto-deleted by the
# worker's cleanup thread. Set to 0 to keep forever.
JOB_TTL_DAYS=7

# Ghidra version used by the decompiler image (pwn + rev). Override and
# rebuild to switch versions. Both must match a GitHub release:
#   ghidra_<VERSION>_PUBLIC_<DATE>.zip
GHIDRA_VERSION=12.0.4
GHIDRA_BUILD_DATE=20260303

# Shared auth token. If non-empty, the Web UI and API require this token
# (Authorization: Bearer <token> or ?token=<token>). Empty = no auth.
AUTH_TOKEN=
